# ==========================================
# AI-MENTOR BACKEND ADMIN — ENVIRONMENT
# ==========================================
# This is a template file.
# Copy this file, rename the copy to `.env`, and fill in your actual values.

# ------------------------------------------
# 1. Server
# ------------------------------------------

# Port the admin backend runs on.
# Use 5001 to avoid conflict with the main backend (which runs on 5000).
PORT=5001

# URL of the frontend admin dashboard.
# Used to set the allowed CORS origin so the browser can talk to this server.
FRONTEND_ADMIN_URL=http://localhost:5174

# ------------------------------------------
# 2. Authentication
# ------------------------------------------

# Secret key used to sign and verify JWT tokens.
# Keep this long, random, and private — changing it will invalidate all active sessions.
JWT_SECRET=your_super_secret_jwt_key

# ------------------------------------------
# 3. Database — Neon DB (Cloud / Production)
# ------------------------------------------

# Full connection string for your Neon PostgreSQL database.
# Must match the main backend's database (both services share the same DB).
# Get it from: https://console.neon.tech → your project → Connection Details
NEON_DATABASE_URL=postgresql://neondb_owner:your_password@your_host/your_db?sslmode=require

# ------------------------------------------
# 4. Database — Local PostgreSQL (Optional)
# ------------------------------------------
# These are only used when NEON_DATABASE_URL is NOT set.
# Useful for running the project locally without a Neon account.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=postgres
DB_PASSWORD=

# ------------------------------------------
# 5. Super Admin Seed
# ------------------------------------------
# Used only when running: npm run seed:superadmin
# This command creates the first admin account in the database.
# You can change these values after seeding by updating the DB directly.

SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=strong_admin_password
